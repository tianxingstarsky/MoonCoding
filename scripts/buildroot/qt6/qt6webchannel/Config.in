config BR2_PACKAGE_QT6WEBCHANNEL
	bool "qt6webchannel"
	select BR2_PACKAGE_QT6BASE_NETWORK
	help
	  Qt WebChannel enables peer-to-peer communication between a
	  server (QML/C++ application) and a client (HTML/JavaScript or
	  QML application).

	  Required by Qt WebEngine.

	  https://doc.qt.io/qt-6/qtwebchannel-index.html
